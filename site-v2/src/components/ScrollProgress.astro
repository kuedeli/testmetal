---
// Editorial scroll progress indicator — left edge hairline + chapter readout
---
<aside class="fixed left-0 top-0 bottom-0 z-30 hidden lg:block pointer-events-none" aria-hidden="true">
  <div class="relative h-full w-8 flex items-start justify-center pt-28">
    <div class="relative h-[calc(100%-8rem)] w-px bg-[color:var(--color-line)]">
      <div
        id="scroll-progress-bar"
        class="absolute top-0 left-0 w-px bg-gradient-to-b from-ember-300 to-brass-300 origin-top"
        style="height: 0%"
      ></div>
    </div>
    <div id="scroll-progress-pct" class="absolute top-8 font-mono text-[10px] text-bone-400 tracking-widest2 tabular">00</div>
  </div>
</aside>

<script>
  const bar = document.getElementById('scroll-progress-bar');
  const pct = document.getElementById('scroll-progress-pct');
  const onScroll = () => {
    const h = document.documentElement;
    const scrolled = h.scrollTop;
    const total = h.scrollHeight - h.clientHeight;
    const ratio = total > 0 ? Math.max(0, Math.min(1, scrolled / total)) : 0;
    if (bar) bar.style.height = `${(ratio * 100).toFixed(1)}%`;
    if (pct) pct.textContent = String(Math.round(ratio * 100)).padStart(2, '0');
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
