---
import type { Product } from '../data/products';
interface Props {
  product: Product;
  index?: number;
  size?: 'md' | 'lg';
}
const { product, index = 0, size = 'md' } = Astro.props;

const priceDisplay = product.priceLabel
  ? product.priceLabel
  : `ab CHF ${product.basePrice.toLocaleString('de-CH')}.–`;

const href = product.category === 'feuer' ? `/produkte/${product.slug}/` : `/garten-moebel/#${product.slug}`;

// Tri-word italic treatment — editorial manifesto
const words = product.name.split(' ');
const head = words.slice(0, -1).join(' ');
const tail = words.slice(-1)[0];
---
<a href={href} class="group relative block overflow-hidden surface-card reveal" style={`transition-delay: ${index * 80}ms`}>
  <!-- Image -->
  <div class={size === 'lg' ? 'aspect-[4/5] overflow-hidden' : 'aspect-[4/5] overflow-hidden'}>
    <img
      src={product.thumbImage}
      alt={product.name}
      class="w-full h-full object-cover transition-transform duration-[1600ms] group-hover:scale-[1.05]"
      style="transition-timing-function: var(--easing-spring);"
      loading="lazy"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-ink-900 via-ink-900/35 to-transparent opacity-85"></div>
    <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none">
      <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-ember-300/15 to-transparent"></div>
    </div>
  </div>

  <!-- Number marker top-left -->
  <div class="absolute top-5 left-5 number-marker z-10">
    <span class="text-ember-300">/</span> {String(index + 1).padStart(2, '0')}
  </div>

  <!-- Arrow indicator top-right -->
  <div class="absolute top-5 right-5 w-11 h-11 border border-bone-200/30 flex items-center justify-center text-bone-50 transition-all duration-500 group-hover:border-ember-300 group-hover:bg-ember-300 group-hover:text-ink-900 z-10" style="transition-timing-function: var(--easing-spring);">
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="transition-transform duration-500 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
      <path d="M2 12L12 2M12 2H4M12 2V10" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
    </svg>
  </div>

  <!-- Content -->
  <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 z-10">
    <div class="flex items-end justify-between gap-4">
      <div class="min-w-0 flex-1">
        <h3 class="font-display text-3xl md:text-4xl lg:text-5xl text-bone-50 leading-[0.95] tracking-tight">
          {head && <span>{head} </span>}<span class="italic-ember">{tail}</span>
        </h3>
        <p class="font-mono text-[10px] uppercase tracking-widest3 text-bone-300 mt-3">{product.subtitle}</p>
      </div>
      <div class="text-right shrink-0">
        <div class="font-mono text-[9px] uppercase tracking-widest3 text-bone-400 mb-1">Preis</div>
        <div class="font-display text-lg md:text-xl text-bone-50 tabular whitespace-nowrap">{priceDisplay}</div>
      </div>
    </div>
    <div class="mt-4 overflow-hidden max-h-0 group-hover:max-h-32 transition-all duration-700 ease-out">
      <p class="text-sm text-bone-100 text-pretty leading-relaxed opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100 font-serif italic">
        {product.tagline}
      </p>
    </div>
  </div>

  <!-- Hover line accent -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-ember-300 origin-left scale-x-0 transition-transform duration-700 group-hover:scale-x-100" style="transition-timing-function: var(--easing-spring);"></div>
</a>
