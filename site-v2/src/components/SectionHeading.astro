---
interface Props {
  eyebrow?: string;
  number?: string;
  title: string;
  titleItalic?: string;
  lead?: string;
  align?: 'left' | 'center';
}
const { eyebrow, number, title, titleItalic, lead, align = 'left' } = Astro.props;
---
<div class:list={['flex flex-col gap-6', align === 'center' ? 'items-center text-center' : 'items-start']}>
  {(eyebrow || number) && (
    <div class="flex items-center gap-5">
      {number && <span class="font-mono text-[11px] text-ember-300 tracking-widest3 tabular">{number}</span>}
      <span class="h-px w-16 bg-ember-300/50"></span>
      {eyebrow && <span class="font-mono text-[11px] uppercase tracking-widest3 text-bone-400">{eyebrow}</span>}
    </div>
  )}
  <h2 class="font-display text-display-lg leading-[0.9] tracking-tight text-balance">
    <slot name="title">
      {title}
      {titleItalic && <span class="italic-ember"> {titleItalic}</span>}
    </slot>
  </h2>
  {lead && (
    <p class="font-serif text-lg md:text-xl text-bone-200 max-w-copy text-pretty leading-relaxed">{lead}</p>
  )}
</div>
