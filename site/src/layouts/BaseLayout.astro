---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  theme?: 'dark' | 'warm';
}

const {
  title,
  description = site.description,
  ogImage = '/images/homepage_368edd_7d7579fc40964818ab033182037607d9_7Emv2_jpg.jpg',
  theme = 'dark',
} = Astro.props;

const pageTitle = title ? `${title} · ${site.name}` : `${site.name} — ${site.tagline}`;
---
<!doctype html>
<html lang="de" class={theme === 'warm' ? 'theme-warm' : ''}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0B0B0C" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_CH" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Manrope:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class="bg-ink-900 text-bone-50 font-sans antialiased">
    <a href="#content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-ember-300 focus:text-ink-900 focus:px-4 focus:py-2">
      Zum Inhalt springen
    </a>
    <Header />
    <main id="content">
      <slot />
    </main>
    <Footer />

    <script>
      // Intersection observer for reveal animations
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15, rootMargin: '0px 0px -60px 0px' },
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
