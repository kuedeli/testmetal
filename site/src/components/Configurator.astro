---
import type { Product } from '../data/products';
interface Props {
  product: Product;
}
const { product } = Astro.props;
---
<div class="configurator relative bg-ink-800 border border-ink-600 p-6 md:p-10" data-configurator data-base-price={product.basePrice}>
  <div class="flex items-end justify-between gap-4 mb-6">
    <div>
      <div class="eyebrow mb-2">Konfigurator</div>
      <h3 class="font-display text-2xl md:text-3xl tracking-tight">Ihre Ausführung</h3>
    </div>
    <span class="font-mono text-[11px] uppercase tracking-widest2 text-bone-400">Echtzeit</span>
  </div>

  {product.variants && product.variants.length > 0 && (
    <fieldset class="mb-8">
      <legend class="font-mono text-[11px] uppercase tracking-widest2 text-bone-400 mb-4">Grundausführung</legend>
      <div class="space-y-2">
        {product.variants.map((v, i) => (
          <label class="group flex items-start gap-4 cursor-pointer border-b border-ink-600 pb-3 hover:border-ember-300/50 transition-colors">
            <input
              type="radio"
              name="variant"
              value={v.price}
              data-label={v.label}
              checked={i === 0}
              class="peer sr-only"
            />
            <span class="mt-1 h-4 w-4 shrink-0 rounded-full border border-bone-400 peer-checked:border-ember-300 peer-checked:bg-ember-300 transition-all"></span>
            <div class="flex-1 flex items-start justify-between gap-4">
              <div>
                <div class="text-base text-bone-50 group-hover:text-ember-300 transition-colors">{v.label}</div>
                {v.description && <div class="text-xs text-bone-400 mt-0.5">{v.description}</div>}
              </div>
              <div class="font-mono text-sm text-bone-100 shrink-0">CHF {v.price.toLocaleString('de-CH')}.–</div>
            </div>
          </label>
        ))}
      </div>
    </fieldset>
  )}

  {product.options && product.options.length > 0 && (
    <fieldset class="mb-8">
      <legend class="font-mono text-[11px] uppercase tracking-widest2 text-bone-400 mb-4">Optionen & Zubehör</legend>
      <div class="space-y-2">
        {product.options.map((o) => (
          <label class="group flex items-start gap-4 cursor-pointer border-b border-ink-600 pb-3 hover:border-ember-300/50 transition-colors">
            <input
              type="checkbox"
              name="option"
              value={o.priceAdd}
              data-label={o.label}
              class="peer sr-only"
            />
            <span class="mt-1 h-4 w-4 shrink-0 border border-bone-400 peer-checked:border-ember-300 peer-checked:bg-ember-300 flex items-center justify-center transition-all">
              <svg class="opacity-0 peer-checked:opacity-100" width="10" height="8" viewBox="0 0 10 8" fill="none" aria-hidden="true">
                <path d="M1 4L3.5 6.5L9 1" stroke="#0B0B0C" stroke-width="1.5"/>
              </svg>
            </span>
            <div class="flex-1 flex items-start justify-between gap-4">
              <div>
                <div class="text-base text-bone-50 group-hover:text-ember-300 transition-colors">{o.label}</div>
                {o.note && <div class="text-xs text-bone-400 mt-0.5">{o.note}</div>}
              </div>
              <div class="font-mono text-sm text-bone-100 shrink-0">+ CHF {o.priceAdd.toLocaleString('de-CH')}.–</div>
            </div>
          </label>
        ))}
      </div>
    </fieldset>
  )}

  <div class="border-t border-ink-500 pt-6 flex items-end justify-between gap-4">
    <div>
      <div class="font-mono text-[11px] uppercase tracking-widest2 text-bone-400 mb-1">Total inkl. MwSt.</div>
      <div class="font-display text-display-sm text-ember-300" data-total>CHF {product.basePrice.toLocaleString('de-CH')}.–</div>
    </div>
    <a
      href={`/kontakt/?produkt=${encodeURIComponent(product.name)}`}
      class="btn-primary shrink-0"
      data-inquiry-btn
    >
      Anfragen
      <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
        <path d="M1 5H13M13 5L9 1M13 5L9 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
      </svg>
    </a>
  </div>

  <p class="mt-4 text-xs text-bone-400">
    Unverbindliche Kalkulation. Alle Preise inkl. MwSt. Endgültiger Preis nach individueller Absprache.
  </p>
</div>

<script>
  const formatCHF = (n: number) => `CHF ${n.toLocaleString('de-CH')}.–`;
  const productName = document.querySelector<HTMLElement>('[data-product-name]')?.dataset.productName ?? '';

  document.querySelectorAll<HTMLElement>('[data-configurator]').forEach((root) => {
    const totalEl = root.querySelector('[data-total]') as HTMLElement | null;
    const inquiryBtn = root.querySelector<HTMLAnchorElement>('[data-inquiry-btn]');
    const baseFallback = Number(root.dataset.basePrice ?? 0);

    const recalc = () => {
      const variant = root.querySelector<HTMLInputElement>('input[name="variant"]:checked');
      const options = root.querySelectorAll<HTMLInputElement>('input[name="option"]:checked');
      const base = variant ? Number(variant.value) : baseFallback;
      const extras = Array.from(options).reduce((sum, o) => sum + Number(o.value), 0);
      const total = base + extras;

      if (totalEl) totalEl.textContent = formatCHF(total);

      if (inquiryBtn) {
        const selectedLabel = variant?.dataset.label ?? '';
        const optLabels = Array.from(options).map((o) => o.dataset.label ?? '').filter(Boolean);
        const summary = [selectedLabel, ...optLabels].filter(Boolean).join(' + ');
        const href = `/kontakt/?produkt=${encodeURIComponent(productName)}&konfig=${encodeURIComponent(summary)}&total=${total}`;
        inquiryBtn.setAttribute('href', href);
      }
    };

    root.querySelectorAll<HTMLInputElement>('input').forEach((input) => {
      input.addEventListener('change', recalc);
    });
    recalc();
  });
</script>
