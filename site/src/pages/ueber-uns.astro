---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { site, pillars } from '../data/site';

const workshopImage = '/images/homepage_368edd_1a9cd367397f48378c324d18505d7916_mv2_d_5152_3864_s_4_.jpg';
const femImage = '/images/homepage_368edd_32b0294a338746cab7192205fe2d5517_mv2_png.png';
const detailImage = '/images/homepage_368edd_d9851b0f3e544d8ab50760870914f9a2_mv2_d_2560_1920_s_2_.jpg';
const portraitImage = '/images/homepage_368edd_e77a13703581407bbe54d019677390e4_mv2_jpg.jpg';
---
<BaseLayout
  title="Über uns"
  description="Fabian Schmitter — Polymechaniker EFZ, dipl. Masch.-Ing. FH, MBA Luzern. Patentbeteiligung in der Maschinenindustrie. Ein Ingenieur, eine Werkstatt, eine Vision."
>
  <!-- HERO -->
  <section class="relative pt-40 md:pt-48 pb-10 border-b border-ink-600">
    <div class="container-page">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-end">
        <div class="lg:col-span-7">
          <div class="eyebrow mb-6 reveal">Über uns</div>
          <h1 class="font-display text-display-xl leading-[0.9] tracking-tight text-balance reveal" style="transition-delay: 100ms;">
            Ein Ingenieur.
            <span class="block italic text-ember-300">Eine Werkstatt.</span>
          </h1>
        </div>
        <div class="lg:col-span-5">
          <p class="text-lg text-bone-200 text-pretty reveal" style="transition-delay: 200ms;">
            Fabian Schmitter verbindet drei Welten, die selten zusammenkommen: die Präzision
            eines Maschineningenieurs, das Handwerk eines Polymechanikers und die Perspektive
            eines MBA-Absolventen.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- PORTRAIT BLOCK -->
  <section class="py-24 md:py-28">
    <div class="container-page">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-start">
        <div class="lg:col-span-6">
          <div class="relative aspect-[4/5] overflow-hidden">
            <img src={workshopImage} alt="Fabian Schmitter in der Werkstatt" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-ink-900/50 to-transparent"></div>
            <div class="absolute bottom-6 left-6 right-6">
              <div class="font-mono text-[10px] uppercase tracking-widest2 text-bone-400 mb-1">Inhaber</div>
              <div class="font-display text-2xl text-bone-50">{site.owner.name}</div>
              <div class="font-mono text-[11px] text-bone-200 uppercase tracking-widest2 mt-1">{site.owner.title}</div>
            </div>
          </div>
        </div>

        <div class="lg:col-span-6 lg:col-start-7 space-y-8 text-lg leading-relaxed text-bone-100 text-pretty">
          <p class="reveal">
            Fabian hat seine Ausbildung als Polymechaniker EFZ begonnen — dem traditionellen
            Weg des Schweizer Präzisionshandwerks. Es folgten Jahre an Erfahrung in der
            Metallverarbeitung, eine Weiterbildung zum Dipl. Maschineningenieur FH und schliesslich
            ein MBA an der Hochschule Luzern.
          </p>
          <p class="reveal">
            Dazwischen entstanden Patentbeteiligungen in der Maschinenindustrie, darunter
            <span class="text-ember-300 font-medium">{site.patent}</span> ({site.patentTitle}).
            Dieses Spektrum — von der Schwingungsdämpfer-Konstruktion bis zum Grill-Eigenbau —
            ist Kern von metal-works.ch.
          </p>
          <p class="reveal">
            Dass ein einzelner Mensch alle Schritte selbst ausführt — Konstruktion, Berechnung,
            Zuschnitt, Schweissen, Finish — ist heute selten. Bei metal-works.ch ist es Prinzip.
          </p>

          <div class="grid grid-cols-2 gap-6 pt-8 border-t border-ink-600">
            <div>
              <div class="font-display text-display-sm text-ember-300">Polymechaniker</div>
              <div class="font-mono text-[10px] uppercase tracking-widest2 text-bone-400 mt-1">EFZ</div>
            </div>
            <div>
              <div class="font-display text-display-sm text-ember-300">Ingenieur</div>
              <div class="font-mono text-[10px] uppercase tracking-widest2 text-bone-400 mt-1">Dipl. Masch.-Ing. FH</div>
            </div>
            <div>
              <div class="font-display text-display-sm text-ember-300">MBA</div>
              <div class="font-mono text-[10px] uppercase tracking-widest2 text-bone-400 mt-1">Luzern</div>
            </div>
            <div>
              <div class="font-display text-display-sm text-ember-300">Patent</div>
              <div class="font-mono text-[10px] uppercase tracking-widest2 text-bone-400 mt-1">{site.patent}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="py-24 md:py-30 bg-ink-800/50 border-y border-ink-600">
    <div class="container-page">
      <div class="max-w-4xl mb-16">
        <SectionHeading
          number="02"
          eyebrow="Werkstattprozess"
          title="Von der Zeichnung"
          titleItalic="zur Patina."
          lead="Jedes Stück durchläuft die gleichen fünf Stationen. Es gibt kein Zwischenhandwerk, keine ausgelagerte Fertigung — vom ersten Strich im CAD bis zur finalen Oberfläche ist alles in einer Hand."
        />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-5 gap-px bg-ink-600">
        {[
          { n: '01', t: 'Konstruktion', d: 'CAD-Modellierung mit Fokus auf Fertigbarkeit und Transport' },
          { n: '02', t: 'Berechnung', d: 'FEM-Simulation, Festigkeit, thermische Belastung' },
          { n: '03', t: 'Zuschnitt', d: 'Plasma- und CNC-Schnitt der 5-10 mm Stahlplatten' },
          { n: '04', t: 'Schweissen', d: 'Präzises Verbinden — Schweissnaht ist Konstruktionselement' },
          { n: '05', t: 'Finish', d: 'Sandstrahlen, Lackieren, Wachsen oder Rohbelassen' },
        ].map((step, i) => (
          <div class="bg-ink-900 p-8 reveal" style={`transition-delay: ${i * 100}ms`}>
            <div class="font-mono text-[11px] text-ember-300 tracking-widest2 mb-6">{step.n}</div>
            <div class="font-display text-2xl mb-3">{step.t}</div>
            <p class="text-sm text-bone-200 text-pretty">{step.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ENGINEERING / FEM -->
  <section class="py-24 md:py-30 bg-ink-900">
    <div class="container-page">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-center">
        <div class="lg:col-span-6">
          <div class="relative aspect-[4/3] overflow-hidden bg-ink-800">
            <img src={femImage} alt="FEM-Simulation" class="w-full h-full object-contain p-8" loading="lazy" />
          </div>
        </div>
        <div class="lg:col-span-6">
          <SectionHeading
            number="03"
            eyebrow="Engineering"
            title="Bevor Stahl fliesst,"
            titleItalic="fliessen Zahlen."
          />
          <p class="mt-8 text-lg text-bone-100 leading-relaxed text-pretty">
            FEM-Simulationen, Festigkeitsberechnungen, Wärmeübergänge: was in der Schwerindustrie Standard ist,
            ist hier Alltag. Deshalb verziehen sich Feuerkugeln auch nach Jahren nicht. Deshalb ist die Geometrie
            der asymmetrischen Variante kein Gimmick, sondern durchgerechnete Funktion.
          </p>
          <p class="mt-4 text-bone-200 text-pretty">
            Kein Stück verlässt die Werkstatt, das nicht vorher im Modell gedacht war.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- VALUES / PILLARS -->
  <section class="py-24 md:py-30 bg-ink-800/50 border-t border-ink-600">
    <div class="container-page">
      <div class="max-w-4xl mb-16">
        <SectionHeading
          number="04"
          eyebrow="Werte"
          title="Was uns"
          titleItalic="antreibt."
        />
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {pillars.map((p, i) => (
          <div class="bg-ink-900 border border-ink-600 p-8 reveal" style={`transition-delay: ${i * 100}ms`}>
            <div class="font-mono text-[11px] text-ember-300 tracking-widest2 mb-4">{p.kicker}</div>
            <h3 class="font-display text-3xl mb-4">{p.title}</h3>
            <p class="text-bone-200 text-sm text-pretty">{p.lead}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 md:py-30 bg-ink-900 relative overflow-hidden">
    <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full blur-[120px] bg-ember-400/10 pointer-events-none animate-flicker"></div>
    <div class="container-page relative z-10 text-center max-w-3xl mx-auto">
      <h2 class="font-display text-display-lg tracking-tight">
        Fragen zum <span class="italic text-ember-300">Prozess?</span>
      </h2>
      <p class="mt-6 text-bone-200 text-lg">
        Rufen Sie an, schreiben Sie — Fabian antwortet selbst.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-5">
        <a href="/kontakt/" class="btn-primary">Jetzt kontaktieren</a>
        <a href={`tel:${site.contact.phone}`} class="btn-ghost">{site.contact.phoneDisplay}</a>
      </div>
    </div>
  </section>
</BaseLayout>
