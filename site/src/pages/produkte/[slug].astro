---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Gallery from '../../components/Gallery.astro';
import Configurator from '../../components/Configurator.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products } from '../../data/products';

export async function getStaticPaths() {
  return products.map((p) => ({
    params: { slug: p.slug },
    props: { product: p },
  }));
}

const { product } = Astro.props;
const related = products.filter((p) => p.slug !== product.slug);
---
<BaseLayout title={product.name} description={product.tagline} ogImage={product.heroImage}>
  <!-- HERO -->
  <section class="relative pt-32 md:pt-36 pb-10 md:pb-16">
    <div class="container-page">
      <div class="flex items-center gap-3 mb-8 reveal">
        <a href="/produkte/" class="font-mono text-[11px] uppercase tracking-widest2 text-bone-400 hover:text-ember-300 transition-colors">
          ← Alle Produkte
        </a>
        <span class="font-mono text-[11px] text-ink-500">/</span>
        <span class="font-mono text-[11px] uppercase tracking-widest2 text-bone-400">{product.name}</span>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-start">
        <!-- LEFT — Meta & name -->
        <div class="lg:col-span-4 lg:sticky lg:top-28">
          <div class="eyebrow mb-4">{product.subtitle}</div>
          <h1 data-product-name={product.name} class="font-display text-display-xl leading-[0.9] tracking-tight text-balance reveal">
            {product.name.split(' ').slice(0, -1).join(' ')} <span class="italic text-ember-300">{product.name.split(' ').slice(-1)[0]}</span>
          </h1>
          <p class="mt-6 text-lg text-bone-200 text-pretty">{product.tagline}</p>

          <div class="mt-8 pt-8 border-t border-ink-600">
            <div class="flex items-end gap-4">
              <div>
                <div class="font-mono text-[11px] uppercase tracking-widest2 text-bone-400 mb-1">Preis ab</div>
                <div class="font-display text-display-md text-ember-300 leading-none">
                  CHF {product.basePrice.toLocaleString('de-CH')}.–
                </div>
              </div>
              <div class="font-mono text-[10px] uppercase tracking-widest2 text-bone-400 pb-1">inkl. MwSt.</div>
            </div>
            <a href={`/kontakt/?produkt=${encodeURIComponent(product.name)}`} class="btn-primary mt-8 w-full justify-center">
              Konfiguration anfragen
              <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                <path d="M1 5H13M13 5L9 1M13 5L9 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- RIGHT — Gallery -->
        <div class="lg:col-span-8">
          <Gallery images={product.gallery} alt={product.name} />
        </div>
      </div>
    </div>
  </section>

  <!-- LEAD / STORY -->
  <section class="py-24 md:py-28 bg-ink-800/50 border-y border-ink-600">
    <div class="container-page">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">
        <div class="lg:col-span-5">
          <SectionHeading
            number="01"
            eyebrow="Prinzip"
            title="Mehr als"
            titleItalic="nur Metall."
          />
        </div>
        <div class="lg:col-span-7 space-y-6 text-lg text-bone-100 leading-relaxed text-pretty reveal">
          <p>{product.lead}</p>
          {product.story && <p>{product.story}</p>}
        </div>
      </div>
    </div>
  </section>

  <!-- SPECS + HIGHLIGHTS -->
  <section class="py-24 md:py-28 bg-ink-900">
    <div class="container-page">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14">
        <!-- Highlights -->
        <div class="lg:col-span-5">
          <div class="eyebrow mb-6">Highlights</div>
          <ul class="space-y-0">
            {product.highlights.map((h, i) => (
              <li class="flex items-start gap-6 border-t border-ink-600 py-5 first:border-t-0 reveal" style={`transition-delay: ${i * 80}ms`}>
                <span class="font-mono text-[11px] text-ember-300 tracking-widest2 w-6 pt-1 shrink-0">0{i + 1}</span>
                <span class="text-lg text-bone-50 text-pretty">{h}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Specs table -->
        <div class="lg:col-span-7 lg:col-start-7">
          <div class="eyebrow mb-6">Technische Daten</div>
          <div class="bg-ink-800 border border-ink-600">
            <table class="w-full">
              <tbody>
                {product.specs.map((s, i) => (
                  <tr class={i !== 0 ? 'border-t border-ink-600' : ''}>
                    <th class="text-left align-top py-4 px-5 md:px-7 font-mono text-[11px] uppercase tracking-widest2 text-bone-400 w-2/5">
                      {s.label}
                    </th>
                    <td class="py-4 px-5 md:px-7 text-bone-50 font-sans text-base">
                      {s.value}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          {product.comparison && (
            <div class="mt-6 bg-gradient-to-br from-ember-400/10 to-ink-800 border border-ember-300/30 p-6">
              <div class="eyebrow mb-3">Vergleich — {product.comparison.label}</div>
              <div class="flex items-baseline gap-4">
                <span class="font-display text-display-sm text-ember-300">{product.comparison.ours}</span>
                <span class="text-bone-400 font-mono text-xs">vs.</span>
                <span class="font-display text-2xl text-bone-400 line-through">{product.comparison.theirs}</span>
                <span class="font-mono text-[10px] uppercase tracking-widest2 text-bone-400 ml-auto">Mitbewerber</span>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- CONFIGURATOR -->
  {(product.variants || product.options) && (
    <section class="py-24 md:py-28 bg-ink-800/50 border-y border-ink-600">
      <div class="container-page">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
          <div class="lg:col-span-5">
            <SectionHeading
              number="02"
              eyebrow="Konfigurieren"
              title="Ihre"
              titleItalic="Zusammenstellung."
              lead="Wählen Sie Grundausführung und Zubehör. Der Preis berechnet sich live. Senden Sie die Konfiguration direkt als Anfrage — wir melden uns mit der finalen Offerte."
            />
            <div class="mt-10 space-y-4 text-sm text-bone-200">
              <div class="flex gap-4">
                <span class="text-ember-300">─</span>
                <span>Unverbindlich — keine Bestellung</span>
              </div>
              <div class="flex gap-4">
                <span class="text-ember-300">─</span>
                <span>Preise sind Richtwerte inkl. MwSt.</span>
              </div>
              <div class="flex gap-4">
                <span class="text-ember-300">─</span>
                <span>Sonderwünsche willkommen</span>
              </div>
            </div>
          </div>
          <div class="lg:col-span-7">
            <Configurator product={product} />
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- RELATED -->
  <section class="py-24 md:py-30 bg-ink-900">
    <div class="container-page">
      <div class="flex items-end justify-between gap-8 mb-12">
        <SectionHeading
          number="03"
          eyebrow="Weiter"
          title="Andere"
          titleItalic="Produktlinien."
        />
        <a href="/produkte/" class="btn-ghost">Alle Produkte</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {related.slice(0, 3).map((p, i) => (
          <ProductCard product={p} index={i} size="md" />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
