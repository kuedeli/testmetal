---
import BaseLayout from '../layouts/BaseLayout.astro';
import InquiryForm from '../components/InquiryForm.astro';
import { site } from '../data/site';
---
<BaseLayout
  title="Kontakt"
  description="Kontakt zu Fabian Schmitter, metal-works.ch. Oberwilerstrasse 13, 8918 Unterlunkhofen."
>
  <!-- HERO -->
  <section class="relative pt-40 md:pt-48 pb-20 border-b border-ink-600">
    <div class="container-page">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-end">
        <div class="lg:col-span-8">
          <div class="eyebrow mb-6 reveal">Kontakt</div>
          <h1 class="font-display text-display-xl leading-[0.9] tracking-tight text-balance reveal" style="transition-delay: 100ms;">
            Sprechen Sie <span class="italic text-ember-300">direkt mit Fabian.</span>
          </h1>
        </div>
        <div class="lg:col-span-4">
          <p class="text-lg text-bone-200 text-pretty reveal" style="transition-delay: 200ms;">
            Keine Hotline, kein Customer Service. Ihr Gegenüber ist der Konstrukteur, Berechner und Monteur Ihres Stücks.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT GRID -->
  <section class="py-20 md:py-24 bg-ink-900">
    <div class="container-page">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-ink-600">
        <!-- Phone -->
        <a href={`tel:${site.contact.phone}`} class="group bg-ink-900 p-10 hover:bg-ink-800 transition-colors duration-500">
          <div class="font-mono text-[11px] uppercase tracking-widest2 text-bone-400 mb-6">01 · Telefon</div>
          <div class="font-display text-3xl md:text-4xl text-bone-50 group-hover:text-ember-300 transition-colors duration-500 tracking-tight">
            {site.contact.phoneDisplay}
          </div>
          <div class="mt-6 font-mono text-[11px] uppercase tracking-widest2 text-ember-300 flex items-center gap-2">
            Direkt anrufen
            <span class="transition-transform duration-500 group-hover:translate-x-1">→</span>
          </div>
        </a>

        <!-- Email -->
        <a href={`mailto:${site.contact.email}`} class="group bg-ink-900 p-10 hover:bg-ink-800 transition-colors duration-500">
          <div class="font-mono text-[11px] uppercase tracking-widest2 text-bone-400 mb-6">02 · E-Mail</div>
          <div class="font-display text-lg md:text-xl text-bone-50 group-hover:text-ember-300 transition-colors duration-500 break-all">
            {site.contact.email}
          </div>
          <div class="mt-6 font-mono text-[11px] uppercase tracking-widest2 text-ember-300 flex items-center gap-2">
            E-Mail schreiben
            <span class="transition-transform duration-500 group-hover:translate-x-1">→</span>
          </div>
        </a>

        <!-- Address -->
        <a href={`https://maps.google.com/?q=${encodeURIComponent(`${site.contact.address.street}, ${site.contact.address.city}`)}`} target="_blank" rel="noopener" class="group bg-ink-900 p-10 hover:bg-ink-800 transition-colors duration-500">
          <div class="font-mono text-[11px] uppercase tracking-widest2 text-bone-400 mb-6">03 · Werkstatt</div>
          <div class="font-display text-xl md:text-2xl text-bone-50 group-hover:text-ember-300 transition-colors duration-500 leading-tight">
            {site.contact.address.street}<br />
            <span class="text-lg md:text-xl">{site.contact.address.city}</span>
          </div>
          <div class="mt-6 font-mono text-[11px] uppercase tracking-widest2 text-ember-300 flex items-center gap-2">
            Route öffnen
            <span class="transition-transform duration-500 group-hover:translate-x-1">↗</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- FORM + SUMMARY -->
  <section class="py-20 md:py-28 bg-ink-800/50 border-y border-ink-600">
    <div class="container-page">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-start">
        <div class="lg:col-span-5">
          <div class="eyebrow mb-5">Anfrage-Zusammenfassung</div>
          <h2 class="font-display text-display-md leading-none tracking-tight mb-8">
            Ihre Anfrage.
          </h2>
          <div id="summary-card" class="bg-ink-800 border border-ink-500 p-6 space-y-4 opacity-60 transition-opacity duration-500">
            <div>
              <div class="font-mono text-[10px] uppercase tracking-widest2 text-bone-400">Produkt</div>
              <div class="font-display text-xl text-ember-300" data-summary-product>—</div>
            </div>
            <div class="hairline"></div>
            <div>
              <div class="font-mono text-[10px] uppercase tracking-widest2 text-bone-400">Konfiguration</div>
              <div class="text-bone-100 text-sm" data-summary-config>Keine Konfiguration übermittelt</div>
            </div>
            <div class="hairline"></div>
            <div>
              <div class="font-mono text-[10px] uppercase tracking-widest2 text-bone-400">Richtpreis</div>
              <div class="font-display text-2xl text-bone-50" data-summary-total>—</div>
            </div>
          </div>
          <p class="mt-6 text-xs text-bone-400">
            Diese Zusammenfassung erscheint automatisch, wenn Sie vom Konfigurator kommen.
            Sie wird mit der Anfrage übermittelt.
          </p>
        </div>

        <div class="lg:col-span-7">
          <InquiryForm title="Anfrage stellen" />
        </div>
      </div>
    </div>
  </section>

  <!-- MAP-ISH BLOCK -->
  <section class="py-24 md:py-30 bg-ink-900">
    <div class="container-page">
      <div class="relative aspect-[21/9] md:aspect-[21/7] overflow-hidden border border-ink-600 bg-ink-800 flex items-center justify-center">
        <!-- SVG location visual -->
        <svg viewBox="0 0 1000 400" class="absolute inset-0 w-full h-full opacity-40" aria-hidden="true">
          <defs>
            <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
              <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#2A2A2E" stroke-width="1" />
            </pattern>
            <radialGradient id="hot" cx="50%" cy="50%" r="40%">
              <stop offset="0%" stop-color="#E8630A" stop-opacity="0.6" />
              <stop offset="100%" stop-color="#E8630A" stop-opacity="0" />
            </radialGradient>
          </defs>
          <rect width="1000" height="400" fill="url(#grid)" />
          <circle cx="500" cy="200" r="100" fill="url(#hot)" />
          <g transform="translate(500 200)">
            <circle r="6" fill="#E8630A" />
            <circle r="16" fill="none" stroke="#E8630A" stroke-width="1" class="animate-ping" />
          </g>
        </svg>
        <div class="relative z-10 text-center">
          <div class="eyebrow mb-4">Standort</div>
          <div class="font-display text-display-md text-bone-50 mb-2">Unterlunkhofen</div>
          <div class="font-mono text-[11px] uppercase tracking-widest2 text-bone-400">
            47.3115° N · 8.3967° E · Kanton Aargau
          </div>
          <a
            href={`https://maps.google.com/?q=${encodeURIComponent(`${site.contact.address.street}, ${site.contact.address.city}`)}`}
            target="_blank"
            rel="noopener"
            class="btn-ghost mt-8"
          >
            Auf Google Maps öffnen
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
              <path d="M1 5H13M13 5L9 1M13 5L9 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Populate summary card from query params
    const params = new URLSearchParams(window.location.search);
    const produkt = params.get('produkt');
    const konfig = params.get('konfig');
    const total = params.get('total');

    const card = document.getElementById('summary-card');
    const pEl = document.querySelector('[data-summary-product]');
    const cEl = document.querySelector('[data-summary-config]');
    const tEl = document.querySelector('[data-summary-total]');

    if (produkt && card && pEl) {
      card.classList.remove('opacity-60');
      card.classList.add('border-ember-300/60', 'glow-ember');
      pEl.textContent = decodeURIComponent(produkt);
      if (konfig && cEl) cEl.textContent = decodeURIComponent(konfig);
      if (total && tEl) tEl.textContent = `CHF ${Number(total).toLocaleString('de-CH')}.–`;
    }
  </script>
</BaseLayout>
